<Window x:Class="PitlaneDanmaku.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Pitlane Danmaku Windows"
        Width="1180"
        Height="760"
        MinWidth="1020"
        MinHeight="680"
        Background="#0D1117">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Pitlane Danmaku"
                           FontSize="30"
                           FontWeight="Bold"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Windows 原生控制台"
                           Foreground="{StaticResource MutedTextBrush}"
                           Margin="0,0,0,20"/>

                <GroupBox Header="B站直播间">
                    <StackPanel>
                        <TextBlock Text="直播间 ID 或 URL"/>
                        <TextBox x:Name="RoomInputBox"/>

                        <TextBlock Text="网页 Cookie"/>
                        <TextBox x:Name="CookieBox"
                                 MinHeight="64"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Text="User-Agent"/>
                        <TextBox x:Name="UserAgentBox" TextWrapping="Wrap"/>

                        <TextBlock Text="buvid3"/>
                        <TextBox x:Name="Buvid3Box"/>

                        <WrapPanel>
                            <Button x:Name="ConnectButton"
                                    Content="连接"
                                    Click="ConnectButton_Click"/>
                            <Button Content="断开"
                                    Background="#FCA5A5"
                                    BorderBrush="#FCA5A5"
                                    Click="DisconnectButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>

                <GroupBox Header="显示和队列">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="OBS 端口"/>
                            <TextBox x:Name="ObsPortBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="发车间隔 ms"/>
                            <TextBox x:Name="LaunchIntervalBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0">
                            <TextBlock Text="等待队列上限"/>
                            <TextBox x:Name="QueueLimitBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2">
                            <TextBlock Text="同屏最少组数"/>
                            <TextBox x:Name="MinVisibleBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="昵称长度"/>
                            <TextBox x:Name="NicknameLengthBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="评论长度"/>
                            <TextBox x:Name="MessageLengthBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="0">
                            <TextBlock Text="重复字符上限"/>
                            <TextBox x:Name="RepeatLimitBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="3" Grid.Column="2">
                            <TextBlock Text="横向最大宽度"/>
                            <TextBox x:Name="MaxStageWidthBox"/>
                        </StackPanel>
                        <CheckBox x:Name="OnlySuperChatBox"
                                  Grid.Row="4"
                                  Grid.ColumnSpan="3"
                                  Content="仅显示醒目留言"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="输出">
                    <StackPanel>
                        <TextBlock Text="OBS 浏览器源"/>
                        <TextBox x:Name="ObsUrlBox"
                                 IsReadOnly="True"
                                 Margin="0,6,0,10"/>
                        <WrapPanel>
                            <Button Content="重启 OBS 服务"
                                    Click="RestartObsButton_Click"/>
                            <Button Content="打开悬浮窗"
                                    Click="OpenOverlayButton_Click"/>
                            <Button Content="隐藏悬浮窗"
                                    Background="#94A3B8"
                                    BorderBrush="#94A3B8"
                                    Click="HideOverlayButton_Click"/>
                        </WrapPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="StatusText"
                                   Text="未连接"
                                   FontSize="24"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="AssetText"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                    <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                        <Button Content="普通评论"
                                Click="SimulateCommentButton_Click"/>
                        <Button Content="醒目留言"
                                Background="#FDE68A"
                                BorderBrush="#FDE68A"
                                Click="SimulateSuperChatButton_Click"/>
                        <Button Content="连发测试"
                                Background="#C4B5FD"
                                BorderBrush="#C4B5FD"
                                Click="BurstButton_Click"/>
                    </WrapPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource PanelBorderBrush}"
                    BorderThickness="1"
                    Padding="14">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="运行日志"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Left"/>
                        <WrapPanel HorizontalAlignment="Right">
                            <Button Content="清空日志"
                                    Click="ClearLogButton_Click"/>
                            <Button Content="导出日志"
                                    Click="ExportLogButton_Click"/>
                        </WrapPanel>
                    </DockPanel>
                    <ListBox x:Name="LogListBox"
                             Grid.Row="1"
                             Background="#0B1018"
                             BorderBrush="#263244"
                             Foreground="{StaticResource TextBrush}"
                             FontFamily="Consolas"
                             FontSize="13"
                             PreviewMouseRightButtonDown="LogListBox_PreviewMouseRightButtonDown">
                        <ListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="复制选中日志"
                                          Click="CopySelectedLogMenuItem_Click"/>
                                <MenuItem Header="复制全部日志"
                                          Click="CopyAllLogsMenuItem_Click"/>
                            </ContextMenu>
                        </ListBox.ContextMenu>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
