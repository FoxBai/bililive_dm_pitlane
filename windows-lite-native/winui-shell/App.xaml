<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="PitlaneDanmaku.Lite.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>

            <Color x:Key="PitlaneInk">#161B22</Color>
            <Color x:Key="PitlaneMutedInk">#61707F</Color>
            <Color x:Key="PitlaneSurface">#F7F8FA</Color>
            <Color x:Key="PitlanePanel">#FFFFFFFF</Color>
            <Color x:Key="PitlaneBorder">#DCE2E8</Color>
            <Color x:Key="PitlaneAccent">#18A058</Color>
            <Color x:Key="PitlaneWarm">#F2A900</Color>

            <SolidColorBrush x:Key="PitlaneInkBrush" Color="{StaticResource PitlaneInk}" />
            <SolidColorBrush x:Key="PitlaneMutedInkBrush" Color="{StaticResource PitlaneMutedInk}" />
            <SolidColorBrush x:Key="PitlaneSurfaceBrush" Color="{StaticResource PitlaneSurface}" />
            <SolidColorBrush x:Key="PitlanePanelBrush" Color="{StaticResource PitlanePanel}" />
            <SolidColorBrush x:Key="PitlaneBorderBrush" Color="{StaticResource PitlaneBorder}" />
            <SolidColorBrush x:Key="PitlaneAccentBrush" Color="{StaticResource PitlaneAccent}" />
            <SolidColorBrush x:Key="PitlaneWarmBrush" Color="{StaticResource PitlaneWarm}" />

            <Style x:Key="SectionTitleText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource PitlaneInkBrush}" />
                <Setter Property="FontSize" Value="18" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="SubtleText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource PitlaneMutedInkBrush}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="TextWrapping" Value="Wrap" />
            </Style>

            <Style x:Key="ToolPanel" TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PitlanePanelBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource PitlaneBorderBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
